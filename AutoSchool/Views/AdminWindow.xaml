<Window x:Class="AutoSchool.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AutoSchool.Views.Controls"
        Title="Панель администратора"
        Width="1200"
        Height="792"
        MinWidth="1050"
        MinHeight="620"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Кнопки бокового меню -->
        <Style x:Key="SidebarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="{DynamicResource AppCursor}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF0078D7"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF66B7F0"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF005A9E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF88C9F7"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка выхода -->
        <Style x:Key="SidebarDangerButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#FF8B1E1E"/>
            <Setter Property="BorderBrush" Value="#FFFFB0B0"/>
            <Setter Property="Foreground" Value="White"/>

            <!-- ВАЖНО: убираем нижний отступ, чтобы кнопка не "обрезалась" -->
            <Setter Property="Margin" Value="0"/>
        </Style>

    </Window.Resources>

    <Grid Background="Transparent" Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== БОКОВАЯ ПАНЕЛЬ ===== -->
        <Border Grid.Column="0"
                CornerRadius="12"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Шапка -->
                <StackPanel Grid.Row="0" Margin="4,2,4,16">
                    <TextBlock Text="Админ-панель"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Управление системой"
                               Foreground="#CCFFFFFF"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Меню -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Content="Билеты"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenTicketsCommand}"/>

                        <Button Content="Вопросы / ответы"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenQuestionsCommand}"/>

                        <Button Content="Пользователи"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenUsersCommand}"/>

                        <Button Content="Инструкторы"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenInstructorsCommand}"/>

                        <Button Content="Результаты"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenResultsCommand}"/>

                        <Button Content="Аналитика"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenAnalyticsCommand}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Низ -->
                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <Border Height="1"
                            Background="#44FFFFFF"
                            Margin="0,0,0,12"/>

                    <Button Content="Выйти"
                            Style="{StaticResource SidebarDangerButtonStyle}"
                            Command="{Binding LogoutCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1"/>

        <!-- ===== КОНТЕНТ ===== -->
        <Border Grid.Column="2"
                CornerRadius="12"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Верхняя строка: заголовок + переключатель темы -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SectionTitle"
                   Grid.Column="0"
                   Text="Раздел"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   VerticalAlignment="Center"/>

                    <controls:ThemeSwitcher Grid.Column="1"
                                VerticalAlignment="Center"/>
                </Grid>

                <!-- Контент -->
                <Frame x:Name="MainFrame"
           Grid.Row="1"
           NavigationUIVisibility="Hidden"/>
            </Grid>
        </Border>
    </Grid>
</Window>