<Window x:Class="AutoSchool.Views.TestPassingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_TestWindowTitle}"
        Height="640" Width="980" MinWidth="920" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ResultCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="6" Opacity="0.22" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock Text="{Binding TicketTitle}"
                       Style="{DynamicResource TestTitleTextStyle}"
                       DockPanel.Dock="Left"/>
            <TextBlock Text="{Binding TimeLeftText}"
                       Style="{DynamicResource TestTimerTextStyle}"
                       DockPanel.Dock="Right"/>
        </DockPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding QuestionNav}" Margin="0,12,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{DynamicResource TestNavButtonStyle}"
                            Command="{Binding DataContext.NavigateToQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <TextBlock Text="{Binding Number}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="2"
                   Text="{Binding ProgressText}"
                   Margin="0,0,0,10"
                   Style="{DynamicResource TestProgressTextStyle}"/>

        <TextBlock Grid.Row="3"
                   Text="{Binding CurrentQuestion.Text}"
                   Margin="0,0,0,12"
                   Style="{DynamicResource TestQuestionTextStyle}"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   MaxHeight="120"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- ВАРИАНТЫ ОТВЕТА (FIX: ClipToBounds + Stretch для переноса) -->
            <Border Grid.Column="0"
                    ClipToBounds="True"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
                <ListBox ItemsSource="{Binding CurrentQuestion.AnswerOptions}"
                         SelectedItem="{Binding SelectedOption}"
                         IsHitTestVisible="{Binding IsOptionsEnabled}"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- ФОТО/КАРТИНКА -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
                <Grid>
                    <Border CornerRadius="8"
                            ClipToBounds="True"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <Image Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Source="{Binding CurrentQuestion.Image, Converter={StaticResource BytesToImage}}"/>
                    </Border>

                    <TextBlock Text="{DynamicResource Str_NoImage}"
                               Foreground="{DynamicResource SubTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentQuestion.Image}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="5"
                   Text="{Binding FeedbackText}"
                   HorizontalAlignment="Center"
                   Margin="0,14,0,0"
                   FontSize="28"
                   FontWeight="Black"
                   Opacity="0.95">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.55" Color="Black"/>
            </TextBlock.Effect>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFeedbackVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFeedbackCorrect}" Value="True">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFeedbackWrong}" Value="True">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <WrapPanel Grid.Row="6" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="{DynamicResource Str_Exit}"
                    MinWidth="120" Height="35" Margin="5"
                    Command="{Binding ExitCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            <Button Content="{DynamicResource Str_Back}"
                    MinWidth="120" Height="35" Margin="5"
                    Command="{Binding PrevCommand}"/>

            <Button Content="{DynamicResource Str_Next}"
                    MinWidth="120" Height="35" Margin="5"
                    Command="{Binding NextCommand}"/>

            <Button Content="{Binding ConfirmButtonText}"
                    MinWidth="160" Height="35" Margin="5"
                    Command="{Binding ConfirmCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </WrapPanel>

        <!-- RESULT OVERLAY -->
        <Border Grid.RowSpan="7"
                Panel.ZIndex="100"
                Background="Transparent"
                Visibility="{Binding IsResultVisible, Converter={StaticResource BoolToVis}}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Style="{StaticResource ResultCardStyle}"
                        Width="620" MaxWidth="720" MaxHeight="520">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl Content="{Binding ResultContent}"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>