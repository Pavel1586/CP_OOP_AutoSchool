<Window x:Class="AutoSchool.Views.TestPassingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тест"
        Height="520" Width="820"
        MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- ФОН ОКНА -->
    <Window.Background>
        <ImageBrush ImageSource="/Assets/background.png"
                    Stretch="Fill"
                    AlignmentX="Center"
                    AlignmentY="Center"/>
    </Window.Background>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Карточка результата (общий стиль) -->
        <Style x:Key="ResultCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="6"
                                      Opacity="0.22"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock Text="{Binding TicketTitle}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#FF1F1F1F"
                       DockPanel.Dock="Left"/>

            <TextBlock Text="{Binding TimeLeftText}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="DarkRed"
                       DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- Лента вопросов -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding QuestionNav}" Margin="0,12,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="34" Height="34" Margin="4"
                            Command="{Binding DataContext.NavigateToQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFE6E6E6"/>
                                <Setter Property="BorderBrush" Value="#FF999999"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                        <Setter Property="Background" Value="#FFBFE9BF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsWrong}" Value="True">
                                        <Setter Property="Background" Value="#FFF3B0B0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF2F74D0"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <TextBlock Text="{Binding Number}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Вопрос + ответы -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ProgressText}"
                           Margin="0,0,0,10"
                           FontSize="14"
                           Foreground="#FF333333"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding CurrentQuestion.Text}"
                           TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="#FF1F1F1F"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="2">
                    <ListBox ItemsSource="{Binding CurrentQuestion.AnswerOptions}"
                             SelectedItem="{Binding SelectedOption}"
                             IsEnabled="{Binding IsOptionsEnabled}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Надпись поверх списка -->
                    <Border CornerRadius="10"
                            Padding="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#CCFFFFFF"
                            BorderBrush="#22CCCCCC"
                            BorderThickness="1"
                            IsHitTestVisible="False">
                        <TextBlock Text="{Binding FeedbackText}"
                                   FontSize="36"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFeedbackVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFeedbackCorrect}" Value="True">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFeedbackWrong}" Value="True">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Кнопки -->
        <WrapPanel Grid.Row="3"
                   HorizontalAlignment="Center"
                   Margin="0,16,0,0">
            <Button Content="Выйти"
                    MinWidth="120"
                    Height="35"
                    Margin="5"
                    Command="{Binding ExitCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            <Button Content="Назад"
                    MinWidth="120"
                    Height="35"
                    Margin="5"
                    Command="{Binding PrevCommand}"/>

            <Button Content="Далее"
                    MinWidth="120"
                    Height="35"
                    Margin="5"
                    Command="{Binding NextCommand}"/>

            <Button Content="{Binding ConfirmButtonText}"
                    MinWidth="160"
                    Height="35"
                    Margin="5"
                    Command="{Binding ConfirmCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </WrapPanel>

        <!-- ===== Встроенный экран результата (без затемнения) ===== -->
        <!-- Background="Transparent" — НЕ затемняет, но блокирует клики по основному окну -->
        <Border Grid.RowSpan="4"
                Panel.ZIndex="100"
                Background="Transparent"
                Visibility="{Binding IsResultVisible, Converter={StaticResource BoolToVis}}">

            <!-- Центрируем карточку -->
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <Border Style="{StaticResource ResultCardStyle}"
                        Width="560"
                        MaxWidth="620"
                        MaxHeight="440">

                    <!-- Контент результата из VM -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ContentControl Content="{Binding ResultContent}"/>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>