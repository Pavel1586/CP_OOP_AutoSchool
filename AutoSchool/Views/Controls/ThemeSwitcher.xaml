<UserControl x:Class="AutoSchool.Views.Controls.ThemeSwitcher"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="32">

	<StackPanel Orientation="Horizontal">
		<Button Content="Светлая"
                Style="{DynamicResource ThemeSwitchButtonStyle}"
                Height="30"
                Margin="0,0,8,0"
                Padding="10,5"
                Click="Light_Click"/>

		<Button Content="Тёмная"
                Style="{DynamicResource ThemeSwitchButtonStyle}"
                Height="30"
                Padding="10,5"
                Click="Dark_Click"/>
	</StackPanel>
</UserControl>