<Window x:Class="AutoSchool.Views.TestResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="Результат теста"
        Height="300" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <!-- ФОН ОКНА -->
    <Window.Background>
        <ImageBrush ImageSource="/Assets/background.png"
                    Stretch="Fill"
                    AlignmentX="Center"
                    AlignmentY="Center"/>
    </Window.Background>
    
    <Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Text="{Binding StatusText}" FontSize="24" FontWeight="Bold"
				   HorizontalAlignment="Center" Margin="0,0,0,15"/>

		<TextBlock Grid.Row="1" Text="{Binding SummaryText}" FontSize="16" Margin="0,0,0,8"/>

		<TextBlock Grid.Row="2" Text="{Binding AnsweredText}" FontSize="14"
				   Foreground="Gray" Margin="0,0,0,10"/>

		<TextBlock Grid.Row="3" Text="{Binding MetaText}" FontSize="12"
				   Foreground="Gray" Margin="0,0,0,15"/>

		<StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
			<Button Content="Разбор" Width="120" Height="35" Margin="5"
					Command="{Binding OpenReviewCommand}"
					CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
			<Button Content="В меню" Width="120" Height="35" Margin="5"
					Command="{Binding ToMenuCommand}"
					CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
		</StackPanel>
	</Grid>
</Window>