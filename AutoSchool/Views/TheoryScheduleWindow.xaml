<Window x:Class="AutoSchool.Views.TheoryScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="Расписание зачётов" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
	
	<!-- ФОН ОКНА -->
	<Window.Background>
		<ImageBrush ImageSource="/Assets/background.png"
                    Stretch="Fill"
                    AlignmentX="Center"
                    AlignmentY="Center"/>
	</Window.Background>
	
    <Window.DataContext>
        <vm:TheoryScheduleViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Расписание зачётов по теории" FontSize="20" FontWeight="Bold"/>

        <TextBlock Grid.Row="1" Margin="0,8,0,10" Foreground="Gray"
                   TextWrapping="Wrap"
                   Text="{Binding TrainingInfoText}"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Credits}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата/время" Binding="{Binding PlannedAt}" Width="160"/>
                <DataGridTextColumn Header="Тема" Binding="{Binding TopicName}" Width="*"/>
                <DataGridTextColumn Header="Длительность" Binding="{Binding DurationMinutes}" Width="110"/>
                <DataGridTextColumn Header="Кабинет" Binding="{Binding Room}" Width="110"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="110"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="Назад" Width="120" Height="35"
                HorizontalAlignment="Center" Margin="0,10,0,0"
                Command="{Binding BackCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Grid>
</Window>