<Window x:Class="AutoSchool.Views.TestReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="Разбор теста" Height="520" Width="900"
        WindowStartupLocation="CenterScreen">

    <!-- ФОН ОКНА -->
    <Window.Background>
        <ImageBrush ImageSource="/Assets/background.png"
                    Stretch="Fill"
                    AlignmentX="Center"
                    AlignmentY="Center"/>
    </Window.Background>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
               Text="{Binding Title}"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
              ItemsSource="{Binding Items}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              CellStyle="{StaticResource WrapCellStyle}"
              ColumnHeaderStyle="{StaticResource WrapHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Вопрос"
                                Binding="{Binding QuestionText}"
                                Width="3*"
                                ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Ваш ответ"
                                Binding="{Binding YourAnswer}"
                                Width="2*"
                                ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Правильный"
                                Binding="{Binding CorrectAnswer}"
                                Width="2*"
                                ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Пояснение"
                                Binding="{Binding Explanation}"
                                Width="3*"
                                ElementStyle="{StaticResource WrapCellTextStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
            Content="Назад"
            Width="120"
            Height="35"
            HorizontalAlignment="Center"
            Margin="0,10,0,0"
            Command="{Binding BackCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Grid>
</Window>