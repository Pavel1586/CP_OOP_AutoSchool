<Window x:Class="AutoSchool.Views.TestReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="{DynamicResource Review}"
        Height="520"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ColumnHeaderStyle="{DynamicResource WrapHeaderStyle}"
                  CellStyle="{DynamicResource WrapCellStyle}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  RowHeight="NaN"
                  MinRowHeight="28">

            <DataGrid.Columns>

                <DataGridTextColumn Binding="{Binding QuestionText}"
                                    Width="360"
                                    ElementStyle="{DynamicResource WrapCellTextStyle}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource Question}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding YourAnswer}"
                                    Width="260"
                                    ElementStyle="{DynamicResource WrapCellTextStyle}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource YourAnswer}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding CorrectAnswer}"
                                    Width="260"
                                    ElementStyle="{DynamicResource WrapCellTextStyle}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource CorrectAnswer}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Explanation}"
                                    Width="420"
                                    ElementStyle="{DynamicResource WrapCellTextStyle}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource Explanation}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
                Content="{DynamicResource Back}"
                Width="120"
                Height="35"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                Command="{Binding BackCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Grid>
</Window>