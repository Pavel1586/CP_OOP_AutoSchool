<Window x:Class="AutoSchool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsTitle}"
        Width="520" Height="360"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource SettingsTitle}"
                   FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource TextBrush}"/>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource ThemeHeader}"
                           FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextBrush}"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{DynamicResource Light}"
                                 Margin="0,0,16,0"
                                 IsChecked="{Binding IsLightTheme, Mode=TwoWay}"/>
                    <RadioButton Content="{DynamicResource Dark}"
                                 IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <StackPanel>
                <TextBlock Text="{DynamicResource LanguageHeader}"
                           FontSize="14" FontWeight="SemiBold"
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource TextBrush}"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{DynamicResource Russian}"
                                 Margin="0,0,16,0"
                                 IsChecked="{Binding IsRussian, Mode=TwoWay}"/>
                    <RadioButton Content="{DynamicResource English}"
                                 IsChecked="{Binding IsEnglish, Mode=TwoWay}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource Close}"
                    MinWidth="110"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>