<Window x:Class="AutoSchool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="520"
        Height="320"
        MinWidth="520"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Настройки"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource TextBrush}"/>

        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">

            <StackPanel>
                <TextBlock Text="Тема оформления"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextBrush}"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Светлая"
                                 Margin="0,0,16,0"
                                 IsChecked="{Binding IsLightTheme, Mode=TwoWay}"/>

                    <RadioButton Content="Тёмная"
                                 IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- место под будущие настройки -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <TextBlock Text="Здесь можно добавить другие настройки (звук, уведомления и т.д.)"
                       Foreground="{DynamicResource SubTextBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Закрыть"
                    MinWidth="110"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>