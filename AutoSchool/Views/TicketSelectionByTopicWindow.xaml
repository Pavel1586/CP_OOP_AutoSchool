<Window x:Class="AutoSchool.Views.TicketSelectionByTopicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="{DynamicResource TicketsByTopicWindowTitle}"
        Height="420" Width="700"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding HeaderText}" FontSize="18" FontWeight="Bold"/>

        <DataGrid Grid.Row="1" Margin="0,10,0,10"
                  ItemsSource="{Binding Tickets}"
                  SelectedItem="{Binding SelectedTicket}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ColumnHeaderStyle="{DynamicResource WrapHeaderStyle}"
                  CellStyle="{DynamicResource WrapCellStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Width="80">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource Id}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Title}" Width="*">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource Ticket}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding TopicQuestionsCount}" Width="150">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource TopicQuestionsCount}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding TotalQuestionsCount}" Width="120">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource TotalQuestionsCount}"/>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{DynamicResource StartTestBtn}" Width="140" Height="35" Margin="5"
                    Command="{Binding OpenTicketCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="{DynamicResource Back}" Width="120" Height="35" Margin="5"
                    Command="{Binding BackCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>