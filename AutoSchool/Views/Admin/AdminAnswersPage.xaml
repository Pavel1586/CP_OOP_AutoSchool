<Page x:Class="AutoSchool.Views.Admin.AdminAnswersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="av"
      Title="Ответы">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding QuestionText}"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Options}"
                  SelectedItem="{Binding SelectedOption}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CellStyle="{StaticResource WrapCellStyle}"
                  ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                  RowHeight="NaN"
                  MinRowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Текст"
                                    Binding="{Binding Text}"
                                    Width="*"
                                    ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Правильный" Binding="{Binding IsCorrectText}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель через StackPanel -->
        <StackPanel Grid.Row="3"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">

            <!-- Если ширины не хватит — появится горизонтальный скролл, кнопки не "исчезнут" -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Добавить" MinWidth="120" Height="35" Margin="5" Command="{Binding AddCommand}"/>
                    <Button Content="Изменить" MinWidth="120" Height="35" Margin="5" Command="{Binding EditCommand}"/>
                    <Button Content="Удалить" MinWidth="120" Height="35" Margin="5" Command="{Binding DeleteCommand}"/>
                    <Button Content="Сделать правильным" MinWidth="180" Height="35" Margin="5" Command="{Binding MarkCorrectCommand}"/>
                    <Button Content="Назад" MinWidth="120" Height="35" Margin="5" Command="{Binding BackCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>