<Page x:Class="AutoSchool.Views.Admin.AdminQuestionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Вопросы">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding CounterText}"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Questions}"
                  SelectedItem="{Binding SelectedQuestion}"
                  SelectionChanged="DataGrid_SelectionChanged"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserResizeRows="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CellStyle="{StaticResource WrapCellStyle}"
                  ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                  RowHeight="NaN"
                  MinRowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Вопрос"
                                    Binding="{Binding Text}"
                                    Width="3*"
                                    ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Пояснение"
                                    Binding="{Binding Explanation}"
                                    Width="2*"
                                    ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Ответов" Binding="{Binding AnswersCount}" Width="110"/>
                <DataGridTextColumn Header="Есть правильный" Binding="{Binding HasCorrect}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,10,0,0">
            <Button Content="Добавить" MinWidth="120" Height="35" Margin="5" Command="{Binding AddCommand}"/>
            <Button Content="Изменить" MinWidth="120" Height="35" Margin="5" Command="{Binding EditCommand}"/>
            <Button Content="Удалить" MinWidth="120" Height="35" Margin="5" Command="{Binding DeleteCommand}"/>
            <Button Content="Ответы" MinWidth="120" Height="35" Margin="5" Command="{Binding OpenAnswersCommand}"/>
            <Button Content="Назад" MinWidth="120" Height="35" Margin="5" Command="{Binding BackCommand}"/>
        </WrapPanel>
    </Grid>
</Page>