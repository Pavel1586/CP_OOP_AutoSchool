<Page x:Class="AutoSchool.Views.Admin.AdminQuestionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вопросы">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding HeaderText}"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding CounterText}"
                       Foreground="{DynamicResource SubTextBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Список вопросов -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Questions}"
                      SelectedItem="{Binding SelectedQuestion}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      CellStyle="{DynamicResource WrapCellStyle}"
                      ColumnHeaderStyle="{DynamicResource WrapHeaderStyle}"
                      RowHeight="NaN"
                      MinRowHeight="28">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Вопрос" Binding="{Binding Text}" Width="3*"
                                        ElementStyle="{DynamicResource WrapCellTextStyle}"/>
                    <DataGridTextColumn Header="Пояснение" Binding="{Binding Explanation}" Width="2*"
                                        ElementStyle="{DynamicResource WrapCellTextStyle}"/>
                    <DataGridTextColumn Header="Ответов" Binding="{Binding AnswersCount}" Width="90"/>
                    <DataGridTextColumn Header="Есть правильный" Binding="{Binding HasCorrect}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Единая форма -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding EditorTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <!-- Текст вопроса -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Текст вопроса"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditQuestionText, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="34"/>
                    </StackPanel>

                    <!-- Пояснение -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Пояснение (необязательно)"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditQuestionExplanation, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="60"/>
                    </StackPanel>

                    <!-- Варианты ответов -->
                    <Border Grid.Row="3"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Варианты ответа (отметь правильный)"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding EditAnswers}"
                                      SelectedItem="{Binding SelectedEditAnswer}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="False"
                                      HeadersVisibility="Column"
                                      RowHeight="NaN"
                                      MinRowHeight="28">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Текст ответа"
                                                        Binding="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"/>
                                    <DataGridTemplateColumn Header="Правильный" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <RadioButton GroupName="CorrectAnswerGroup"
                                                             IsChecked="{Binding IsCorrect, Mode=TwoWay}"
                                                             Command="{Binding DataContext.SetCorrectAnswerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                             CommandParameter="{Binding}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Grid.Row="2"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0">
                                <Button Content="Добавить вариант"
                                        MinWidth="150"
                                        Height="35"
                                        Margin="5"
                                        Command="{Binding AddAnswerCommand}"/>

                                <Button Content="Удалить вариант"
                                        MinWidth="150"
                                        Height="35"
                                        Margin="5"
                                        Command="{Binding RemoveAnswerCommand}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- Ошибки/сообщения -->
                    <TextBlock Grid.Row="4"
                               Text="{Binding ValidationText}"
                               Foreground="{DynamicResource DangerBrush}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>

                    <!-- Кнопки формы -->
                    <WrapPanel Grid.Row="5"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0">
                        <Button Content="Сохранить"
                                MinWidth="140"
                                Height="35"
                                Margin="5"
                                Style="{DynamicResource Win10PrimaryButton}"
                                Command="{Binding SaveQuestionCommand}"/>

                        <Button Content="Отмена"
                                MinWidth="140"
                                Height="35"
                                Margin="5"
                                Command="{Binding CancelEditCommand}"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя панель (минимум) -->
        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0">
            <Button Content="Новый"
                    MinWidth="140"
                    Height="35"
                    Margin="5"
                    Command="{Binding NewQuestionCommand}"/>

            <Button Content="Удалить"
                    MinWidth="140"
                    Height="35"
                    Margin="5"
                    Command="{Binding DeleteQuestionCommand}"/>

            <Button Content="Назад"
                    MinWidth="140"
                    Height="35"
                    Margin="5"
                    Command="{Binding BackCommand}"/>
        </WrapPanel>
    </Grid>
</Page>