<Page x:Class="AutoSchool.Views.Admin.AdminAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Аналитика">

	<Page.Resources>
		<!-- Небольшая тень для "карточек" -->
		<DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="2"
                          Opacity="0.18"
                          Color="#000000"/>

		<!-- Стиль карточки -->
		<Style x:Key="CardStyle" TargetType="Border">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E2E2E2"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="14"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
			<Setter Property="Effect" Value="{StaticResource CardShadow}"/>
		</Style>

		<!-- Заголовки секций -->
		<Style x:Key="SectionTitleStyle" TargetType="TextBlock">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Margin" Value="0,0,0,10"/>
		</Style>
	</Page.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid Margin="12">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- ===== HEADER ===== -->
			<Grid Grid.Row="0" Margin="0,0,0,12">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<StackPanel>
					<TextBlock Text="Аналитика"
                               FontSize="26"
                               FontWeight="Bold"/>
					<TextBlock Text="Сводка по тестам, пользователям и ошибкам"
                               Foreground="Gray"
                               Margin="0,6,0,0"/>
				</StackPanel>

				<Button Grid.Column="1"
                        Content="Назад"
                        MinWidth="120"
                        Height="35"
                        VerticalAlignment="Top"
                        Command="{Binding BackCommand}"/>
			</Grid>

			<!-- ===== FILTERS CARD ===== -->
			<Border Grid.Row="1" Style="{StaticResource CardStyle}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<TextBlock Text="Период:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="Gray"/>

					<DatePicker Grid.Column="1"
                                Width="150"
                                SelectedDate="{Binding DateFrom}"
                                Margin="0,0,8,0"/>

					<TextBlock Grid.Column="2"
                               Text="—"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="Gray"/>

					<DatePicker Grid.Column="3"
                                Width="150"
                                SelectedDate="{Binding DateTo}"
                                Margin="0,0,14,0"/>

					<!-- spacer -->
					<Grid Grid.Column="4"/>

					<Button Grid.Column="5"
                            Content="Обновить"
                            MinWidth="130"
                            Height="32"
                            Margin="0,0,8,0"
                            Style="{StaticResource Win10PrimaryButton}"
                            Command="{Binding RefreshCommand}"/>

					<Button Grid.Column="6"
                            Content="Экспорт CSV"
                            MinWidth="130"
                            Height="32"
                            Command="{Binding ExportCsvCommand}"/>
				</Grid>
			</Border>

			<!-- ===== SUMMARY CARDS ===== -->
			<Border Grid.Row="2" Style="{StaticResource CardStyle}">
				<StackPanel>
					<TextBlock Text="Сводка"
                               Style="{StaticResource SectionTitleStyle}"/>

					<!-- WrapPanel чтобы карточки красиво переносились при изменении ширины окна -->
					<WrapPanel ItemWidth="220"
                               ItemHeight="90"
                               HorizontalAlignment="Left">

						<!-- Card 1 -->
						<Border CornerRadius="8"
                                Background="#FFF8F8F8"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,12">
							<StackPanel>
								<TextBlock Text="Тестов" Foreground="Gray"/>
								<TextBlock Text="{Binding TotalTests}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
							</StackPanel>
						</Border>

						<!-- Card 2 -->
						<Border CornerRadius="8"
                                Background="#FFF8F8F8"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,12">
							<StackPanel>
								<TextBlock Text="Пользователей" Foreground="Gray"/>
								<TextBlock Text="{Binding UniqueUsers}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
							</StackPanel>
						</Border>

						<!-- Card 3 -->
						<Border CornerRadius="8"
                                Background="#FFF8F8F8"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,12">
							<StackPanel>
								<TextBlock Text="Сдано" Foreground="Gray"/>
								<TextBlock Text="{Binding PassedTests}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
							</StackPanel>
						</Border>

						<!-- Card 4 -->
						<Border CornerRadius="8"
                                Background="#FFF8F8F8"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,12">
							<StackPanel>
								<TextBlock Text="Процент сдачи" Foreground="Gray"/>
								<TextBlock Text="{Binding PassRateText}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
							</StackPanel>
						</Border>

						<!-- Card 5 -->
						<Border CornerRadius="8"
                                Background="#FFF8F8F8"
                                BorderBrush="#E3E3E3"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,12">
							<StackPanel>
								<TextBlock Text="Средний результат" Foreground="Gray"/>
								<TextBlock Text="{Binding AvgScoreText}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

					</WrapPanel>
				</StackPanel>
			</Border>

			<!-- ===== DATA (TABS) ===== -->
			<Border Grid.Row="3" Style="{StaticResource CardStyle}">
				<StackPanel>
					<TextBlock Text="Детализация"
                               Style="{StaticResource SectionTitleStyle}"/>

					<TabControl>
						<!-- TOP USERS -->
						<TabItem Header="Топ пользователей">
							<Grid Margin="10">
								<DataGrid ItemsSource="{Binding TopUsers}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          CellStyle="{StaticResource WrapCellStyle}"
                                          ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                                          RowHeight="NaN"
                                          MinRowHeight="28">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Email"
                                                            Binding="{Binding Email}"
                                                            Width="2*"
                                                            ElementStyle="{StaticResource WrapCellTextStyle}"/>
										<DataGridTextColumn Header="Тестов" Binding="{Binding Tests}" Width="90"/>
										<DataGridTextColumn Header="Сдано" Binding="{Binding Passed}" Width="90"/>
										<DataGridTextColumn Header="% сдачи" Binding="{Binding PassRateText}" Width="110"/>
									</DataGrid.Columns>
								</DataGrid>
							</Grid>
						</TabItem>

						<!-- TICKETS -->
						<TabItem Header="Статистика по билетам">
							<Grid Margin="10">
								<DataGrid ItemsSource="{Binding TicketStats}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          CellStyle="{StaticResource WrapCellStyle}"
                                          ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                                          RowHeight="NaN"
                                          MinRowHeight="28">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Билет"
                                                            Binding="{Binding TicketTitle}"
                                                            Width="2*"
                                                            ElementStyle="{StaticResource WrapCellTextStyle}"/>
										<DataGridTextColumn Header="Тестов" Binding="{Binding Tests}" Width="90"/>
										<DataGridTextColumn Header="Сдано" Binding="{Binding Passed}" Width="90"/>
										<DataGridTextColumn Header="% сдачи" Binding="{Binding PassRateText}" Width="110"/>
									</DataGrid.Columns>
								</DataGrid>
							</Grid>
						</TabItem>

						<!-- MISTAKES -->
						<TabItem Header="Топ ошибок">
							<Grid Margin="10">
								<DataGrid ItemsSource="{Binding TopMistakeQuestions}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          CellStyle="{StaticResource WrapCellStyle}"
                                          ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                                          RowHeight="NaN"
                                          MinRowHeight="28">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Билет"
                                                            Binding="{Binding TicketTitle}"
                                                            Width="140"
                                                            ElementStyle="{StaticResource WrapCellTextStyle}"/>
										<DataGridTextColumn Header="Вопрос"
                                                            Binding="{Binding QuestionText}"
                                                            Width="3*"
                                                            ElementStyle="{StaticResource WrapCellTextStyle}"/>
										<DataGridTextColumn Header="Ошибок" Binding="{Binding WrongCount}" Width="90"/>
										<DataGridTextColumn Header="Всего" Binding="{Binding TotalCount}" Width="90"/>
										<DataGridTextColumn Header="%" Binding="{Binding WrongRateText}" Width="80"/>
									</DataGrid.Columns>
								</DataGrid>
							</Grid>
						</TabItem>
					</TabControl>
				</StackPanel>
			</Border>

			<!-- Нижний отступ (на случай очень малого окна) -->
			<Grid Grid.Row="4" Height="10"/>
		</Grid>
	</ScrollViewer>
</Page>