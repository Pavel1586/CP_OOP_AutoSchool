<Window x:Class="AutoSchool.Views.Admin.TicketEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Билет"
        Width="520"
        Height="320"
        MinWidth="520"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <!-- фон окна как в приложении -->
    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <!-- локально для окна: чтобы текст не резался -->
    <Window.Resources>
        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MaxDropDownHeight" Value="240"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
    </Window.Resources>

    <!-- ScrollViewer гарантирует, что низ (кнопки) не пропадёт -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="16">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Название -->
                    <TextBlock Text="Название билета"
                               Foreground="{DynamicResource SubTextBrush}"
                               Margin="0,0,0,6"/>

                    <TextBox x:Name="TitleBox" Grid.Row="1"/>

                    <!-- Тема -->
                    <TextBlock Grid.Row="2"
                               Text="Тема"
                               Foreground="{DynamicResource SubTextBrush}"
                               Margin="0,12,0,6"/>

                    <ComboBox x:Name="TopicBox"
                              Grid.Row="3"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"/>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0">
                        <Button Content="OK"
                                Width="140"
                                Height="36"
                                Margin="8,0"
                                Click="Ok_Click"/>
                        <Button Content="Отмена"
                                Width="140"
                                Height="36"
                                Margin="8,0"
                                Click="Cancel_Click"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>