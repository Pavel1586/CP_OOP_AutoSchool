<Page x:Class="AutoSchool.Views.Admin.AdminTicketsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Билеты">

	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="Билеты"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

		<DataGrid Grid.Row="1"
                  ItemsSource="{Binding Tickets}"
                  SelectedItem="{Binding SelectedTicket}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CellStyle="{StaticResource WrapCellStyle}"
                  ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                  RowHeight="NaN"
                  MinRowHeight="28">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
				<DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"
                                    ElementStyle="{StaticResource WrapCellTextStyle}"/>
				<DataGridTextColumn Header="Вопросов" Binding="{Binding QuestionsCount}" Width="120"/>
			</DataGrid.Columns>
		</DataGrid>

		<WrapPanel Grid.Row="2"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   ItemHeight="35">
			<Button Content="Добавить" MinWidth="120" Height="35" Margin="5" Command="{Binding AddCommand}"/>
			<Button Content="Изменить" MinWidth="120" Height="35" Margin="5" Command="{Binding EditCommand}"/>
			<Button Content="Удалить" MinWidth="120" Height="35" Margin="5" Command="{Binding DeleteCommand}"/>
			<Button Content="Вопросы" MinWidth="120" Height="35" Margin="5" Command="{Binding OpenQuestionsCommand}"/>
		</WrapPanel>
	</Grid>
</Page>