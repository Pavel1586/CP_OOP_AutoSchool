<Window x:Class="AutoSchool.Views.Admin.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Курсант"
        Height="300" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Имя"/>
        <TextBox x:Name="FirstNameBox" Grid.Row="1" Height="28" Margin="0,5,0,10"/>

        <TextBlock Grid.Row="2" Text="Фамилия"/>
        <TextBox x:Name="LastNameBox" Grid.Row="3" Height="28" Margin="0,5,0,10"/>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Email"/>
            <TextBox x:Name="EmailBox" Height="28" Margin="0,5,0,10"/>

            <TextBlock Text="Роль"/>
            <ComboBox x:Name="RoleBox" Height="28" Margin="0,5,0,0">
                <ComboBoxItem Tag="1" Content="Admin"/>
                <ComboBoxItem Tag="2" Content="Client"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="OK" Width="110" Height="35" Margin="5" Click="Ok_Click"/>
                <Button Content="Отмена" Width="110" Height="35" Margin="5" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>