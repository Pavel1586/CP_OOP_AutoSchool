<Window x:Class="AutoSchool.Views.Admin.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Курсант"
        Width="520"
        Height="380"
        MinWidth="520"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Имя" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="FirstNameBox" Grid.Row="1"/>

                <TextBlock Grid.Row="2" Text="Фамилия" Foreground="{DynamicResource SubTextBrush}" Margin="0,12,0,6"/>
                <TextBox x:Name="LastNameBox" Grid.Row="3"/>

                <TextBlock Grid.Row="4" Text="Email" Foreground="{DynamicResource SubTextBrush}" Margin="0,12,0,6"/>
                <TextBox x:Name="EmailBox" Grid.Row="5"/>

                <StackPanel Grid.Row="6" Margin="0,12,0,0">
                    <TextBlock Text="Роль" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="RoleBox">
                        <ComboBoxItem Tag="1" Content="Admin"/>
                        <ComboBoxItem Tag="2" Content="Client"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button Content="OK" Width="120" Height="36" Margin="6" Click="Ok_Click"/>
                        <Button Content="Отмена" Width="120" Height="36" Margin="6" Click="Cancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>