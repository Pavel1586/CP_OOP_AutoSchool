<Page x:Class="AutoSchool.Views.Admin.AdminUserSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Расписание">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- Период обучения -->
        <Border Grid.Row="1"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="10"
                CornerRadius="6"
                Margin="0,0,0,10">
            <!-- убрали ItemHeight -->
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Период обучения:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Width="150" SelectedDate="{Binding TrainingStartDate}" Margin="0,0,8,0"/>
                <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Width="150" SelectedDate="{Binding TrainingPlannedEndDate}" Margin="0,0,14,0"/>
                <Button Content="Сохранить период" MinWidth="170" Height="32" Command="{Binding SavePeriodCommand}"/>
            </WrapPanel>
        </Border>

        <!-- Таблица -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Credits}"
                  SelectedItem="{Binding SelectedCredit}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CellStyle="{StaticResource WrapCellStyle}"
                  ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                  RowHeight="NaN"
                  MinRowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата/время" Binding="{Binding PlannedAt}" Width="170"/>
                <DataGridTextColumn Header="Тема" Binding="{Binding TopicName}" Width="*"
                                    ElementStyle="{StaticResource WrapCellTextStyle}"/>
                <DataGridTextColumn Header="Длит., мин" Binding="{Binding DurationMinutes}" Width="90"/>
                <DataGridTextColumn Header="Кабинет" Binding="{Binding Room}" Width="90"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="220"
                                    ElementStyle="{StaticResource WrapCellTextStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки: убрали ItemHeight, чтобы не обрезались -->
        <WrapPanel Grid.Row="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,10,0,0">
            <Button Content="Добавить" MinWidth="120" Height="35" Margin="5" Command="{Binding AddCommand}"/>
            <Button Content="Изменить" MinWidth="120" Height="35" Margin="5" Command="{Binding EditCommand}"/>
            <Button Content="Удалить" MinWidth="120" Height="35" Margin="5" Command="{Binding DeleteCommand}"/>
            <Button Content="Назад" MinWidth="120" Height="35" Margin="5" Command="{Binding BackCommand}"/>
        </WrapPanel>
    </Grid>
</Page>