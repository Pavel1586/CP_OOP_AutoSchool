<Page x:Class="AutoSchool.Views.Admin.AdminUsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пользователи">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Width="340" Height="32"
                     Margin="0,0,8,0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Найти" MinWidth="120" Height="32" Margin="0,0,8,0" Command="{Binding SearchCommand}"/>
            <Button Content="Сброс" MinWidth="120" Height="32" Command="{Binding ResetCommand}"/>
        </WrapPanel>

        <!-- Таблица -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CellStyle="{StaticResource WrapCellStyle}"
                  ColumnHeaderStyle="{StaticResource WrapHeaderStyle}"
                  RowHeight="NaN"
                  MinRowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="140"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="160"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="120"/>
                <DataGridTextColumn Header="Тестов" Binding="{Binding ResultsCount}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0">
            <Button Content="Изменить" MinWidth="140" Height="35" Margin="5" Command="{Binding EditCommand}"/>
            <Button Content="Удалить" MinWidth="140" Height="35" Margin="5" Command="{Binding DeleteCommand}"/>
            <Button Content="Расписание" MinWidth="140" Height="35" Margin="5" Command="{Binding OpenScheduleCommand}"/>
            <Button Content="Назад" MinWidth="120" Height="35" Margin="5" Command="{Binding BackCommand}"/>
        </WrapPanel>
    </Grid>
</Page>