<Window x:Class="AutoSchool.Views.Admin.TopicEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тема"
        Width="480"
        Height="220"
        MinWidth="480"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

	<Window.Background>
		<DynamicResource ResourceKey="AppBackgroundBrush"/>
	</Window.Background>

	<Window.Resources>
		<Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
			<Setter Property="MinHeight" Value="34"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>
	</Window.Resources>

	<Grid Margin="16">
		<Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<TextBlock Text="Название темы"
                           Foreground="{DynamicResource SubTextBrush}"
                           Margin="0,0,0,6"/>

				<TextBox x:Name="NameBox" Grid.Row="1"/>

				<StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0">
					<Button Content="OK" Width="120" Height="36" Margin="6" Click="Ok_Click"/>
					<Button Content="Отмена" Width="120" Height="36" Margin="6" Click="Cancel_Click"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>