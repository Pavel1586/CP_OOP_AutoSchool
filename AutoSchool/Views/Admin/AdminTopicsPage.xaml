<Page x:Class="AutoSchool.Views.Admin.AdminTopicsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Темы">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Темы" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Topics}"
                  SelectedItem="{Binding SelectedTopic}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Добавить" MinWidth="120" Height="35" Margin="5" Command="{Binding AddCommand}"/>
            <Button Content="Изменить" MinWidth="120" Height="35" Margin="5" Command="{Binding EditCommand}"/>
            <Button Content="Удалить" MinWidth="120" Height="35" Margin="5" Command="{Binding DeleteCommand}"/>
            <Button Content="Назад" MinWidth="120" Height="35" Margin="5" Command="{Binding BackCommand}"/>
        </WrapPanel>
    </Grid>
</Page>