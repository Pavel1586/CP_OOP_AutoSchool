<Window x:Class="AutoSchool.Views.Admin.TheoryCreditEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Зачёт по теории"
        Width="620"
        Height="560"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <!-- Фон окна как в приложении -->
    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <!-- Локальные стили: чтобы текст в полях не резался -->
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MaxDropDownHeight" Value="240"/>
        </Style>

        <Style TargetType="{x:Type DatePicker}" BasedOn="{StaticResource {x:Type DatePicker}}">
            <Setter Property="MinHeight" Value="34"/>
        </Style>
    </Window.Resources>

    <!-- ScrollViewer решает обрезание низа и выпадающих списков -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="16">
            <!-- Карточка -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- дата/время -->
                        <RowDefinition Height="Auto"/>
                        <!-- тема -->
                        <RowDefinition Height="Auto"/>
                        <!-- длит/кабинет -->
                        <RowDefinition Height="Auto"/>
                        <!-- статус -->
                        <RowDefinition Height="Auto"/>
                        <!-- примечание -->
                        <RowDefinition Height="Auto"/>
                        <!-- кнопки -->
                    </Grid.RowDefinitions>

                    <!-- ===== Дата + время ===== -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата" Style="{DynamicResource LabelStyle}"/>
                            <DatePicker x:Name="DatePicker" Width="180"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   Text="Время (HH:mm)"
                                   VerticalAlignment="Bottom"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   Margin="0,0,10,8"/>

                        <TextBox x:Name="TimeBox"
                                 Grid.Column="3"
                                 Width="90"
                                 Text="18:00"
                                 VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- ===== Тема ===== -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,14">
                        <TextBlock Text="Тема" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="TopicBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>
                    </StackPanel>

                    <!-- ===== Длительность + кабинет ===== -->
                    <Grid Grid.Row="2" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Длительность (мин)" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="DurationBox" Text="60"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Кабинет" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="RoomBox" Text="Каб. 1"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Статус ===== -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,14">
                        <TextBlock Text="Статус" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="StatusBox">
                            <ComboBoxItem Tag="Planned" Content="Planned"/>
                            <ComboBoxItem Tag="Passed" Content="Passed"/>
                            <ComboBoxItem Tag="Failed" Content="Failed"/>
                            <ComboBoxItem Tag="Missed" Content="Missed"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- ===== Примечание ===== -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,6">
                        <TextBlock Text="Примечание" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="NotesBox"
                                 MinHeight="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <!-- ===== Кнопки ===== -->
                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0">
                        <Button Content="OK"
                                Width="140"
                                Height="38"
                                Margin="8,0"
                                Click="Ok_Click"/>
                        <Button Content="Отмена"
                                Width="140"
                                Height="38"
                                Margin="8,0"
                                Click="Cancel_Click"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>