<Page x:Class="AutoSchool.Views.Admin.AdminTicketSelectForQuestionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Выбор билета">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите билет для редактирования вопросов/ответов"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Tickets}"
                  SelectedItem="{Binding SelectedTicket}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Вопросов" Binding="{Binding QuestionsCount}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Открыть вопросы" Width="160" Height="35" Margin="5"
                    Command="{Binding OpenQuestionsCommand}"/>
            <Button Content="Назад" Width="120" Height="35" Margin="5"
                    Command="{Binding BackCommand}"/>
        </StackPanel>
    </Grid>
</Page>