<Window x:Class="AutoSchool.Views.ResultsHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="История результатов" Height="420" Width="650"
        WindowStartupLocation="CenterScreen">
	
	<!-- ФОН ОКНА -->
	<Window.Background>
		<ImageBrush ImageSource="/Assets/background.png"
                    Stretch="Fill"
                    AlignmentX="Center"
                    AlignmentY="Center"/>
	</Window.Background>
	
	<Window.DataContext>
		<vm:ResultsHistoryViewModel/>
	</Window.DataContext>

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="История результатов" FontSize="20" FontWeight="Bold" />

		<Grid Grid.Row="1" Margin="0,10,0,10">
			<DataGrid ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedResult}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Дата" Binding="{Binding PassedAt}" Width="*"/>
					<DataGridTextColumn Header="Билет" Binding="{Binding TicketTitle}" Width="*"/>
					<DataGridTextColumn Header="Правильных" Binding="{Binding Correct}" Width="*"/>
					<DataGridTextColumn Header="Ошибок" Binding="{Binding Wrong}" Width="*"/>
					<DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
				</DataGrid.Columns>
			</DataGrid>

			<!-- Сообщение, если история пуста -->
			<TextBlock Text="История пуста. Пройдите тест, чтобы появились результаты."
                       Visibility="{Binding EmptyVisibility}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Margin="20"/>
		</Grid>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
			<Button Content="Открыть" Width="120" Height="35" Margin="5"
                    Command="{Binding OpenSelectedCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
			<Button Content="Назад" Width="120" Height="35" Margin="5"
                    Command="{Binding BackCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
		</StackPanel>
	</Grid>
</Window>