<Window x:Class="AutoSchool.Views.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutoSchool.ViewModels"
        Title="{DynamicResource MainMenuWindowTitle}"
        Height="520" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Background>
        <DynamicResource ResourceKey="AppBackgroundBrush"/>
    </Window.Background>

    <Window.DataContext>
        <vm:MainMenuViewModel/>
    </Window.DataContext>

    <Grid Style="{StaticResource AppRootGridStyle}">
        <Border Style="{StaticResource AppCardStyle}"
            Width="420"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Height="464">
            <StackPanel>
                <TextBlock Text="{Binding WelcomeText}" Style="{StaticResource AppTitleTextStyle}" />
                <TextBlock Text="{Binding InstructorText}" Style="{StaticResource AppSubtitleTextStyle}" />

                <Button Content="{DynamicResource StartTest}" Width="260" Height="42" Margin="0,0,0,10"
                HorizontalAlignment="Center"
                Style="{StaticResource Win10PrimaryButton}"
                Command="{Binding OpenTicketsCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="{DynamicResource ResultsHistory}" Width="260" Height="42" Margin="0,0,0,10"
                HorizontalAlignment="Center"
                Command="{Binding OpenHistoryCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="{DynamicResource ChooseInstructor}" Width="260" Height="42" Margin="0,0,0,10"
                HorizontalAlignment="Center"
                Command="{Binding OpenInstructorCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="{DynamicResource TheorySchedule}" Width="260" Height="42" Margin="0,0,0,18"
                HorizontalAlignment="Center"
                Command="{Binding OpenTheoryScheduleCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Button Content="{DynamicResource Settings}" Width="260" Height="42" Margin="0,0,0,10"
                HorizontalAlignment="Center" Click="OpenSettings_Click"/>

                <Button Content="{DynamicResource Logout}" Width="260" Height="42"
                HorizontalAlignment="Center"
                Command="{Binding LogoutCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>