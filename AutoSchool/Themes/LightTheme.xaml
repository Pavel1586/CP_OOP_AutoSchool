<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Палитра -->
	<SolidColorBrush x:Key="TextBrush" Color="#FF1E1E1E"/>
	<SolidColorBrush x:Key="SubTextBrush" Color="#FF5A5A5A"/>

	<SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
	<SolidColorBrush x:Key="Surface2Brush" Color="#FFF3F5F8"/>
	<SolidColorBrush x:Key="BorderBrush" Color="#FFCDD3DD"/>

	<SolidColorBrush x:Key="AccentBrush" Color="#FF2F74D0"/>
	<SolidColorBrush x:Key="AccentHoverBrush" Color="#FF3B86EA"/>
	<SolidColorBrush x:Key="AccentPressedBrush" Color="#FF245DAA"/>

	<SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFFFF"/>
	<SolidColorBrush x:Key="ControlHoverBrush" Color="#FFF2F6FF"/>
	<SolidColorBrush x:Key="ControlPressedBrush" Color="#FFE7F0FF"/>

	<!-- Window -->
	<Style TargetType="{x:Type Window}">
		<Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="FontFamily" Value="Segoe UI"/>
		<Setter Property="FontSize" Value="13"/>
	</Style>

	<!-- Button -->
	<Style TargetType="{x:Type Button}">
		<Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="12,7"/>
		<Setter Property="Cursor" Value="{DynamicResource AppCursor}"/>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
				<Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
			</Trigger>
			<Trigger Property="IsPressed" Value="True">
				<Setter Property="Background" Value="{DynamicResource ControlPressedBrush}"/>
				<Setter Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}"/>
			</Trigger>
			<Trigger Property="IsEnabled" Value="False">
				<Setter Property="Opacity" Value="0.55"/>
			</Trigger>
		</Style.Triggers>
	</Style>

	<!-- Стиль ТОЛЬКО для кнопок переключателя темы (есть и в Light, и в Dark) -->
	<Style x:Key="ThemeSwitchButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
		<Setter Property="Background" Value="#FF2F74D0"/>
		<Setter Property="BorderBrush" Value="#FF3B86EA"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="BorderThickness" Value="1"/>

		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="#FF3B86EA"/>
			</Trigger>
			<Trigger Property="IsPressed" Value="True">
				<Setter Property="Background" Value="#FF245DAA"/>
			</Trigger>
		</Style.Triggers>
	</Style>

</ResourceDictionary>