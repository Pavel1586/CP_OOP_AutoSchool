<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Палитра -->
	<SolidColorBrush x:Key="TextBrush" Color="#FFE8EAF0"/>
	<SolidColorBrush x:Key="SubTextBrush" Color="#FFAAB0C0"/>

	<SolidColorBrush x:Key="SurfaceBrush" Color="#FF171A21"/>
	<SolidColorBrush x:Key="Surface2Brush" Color="#FF1F2430"/>
	<SolidColorBrush x:Key="BorderBrush" Color="#FF31394A"/>

	<SolidColorBrush x:Key="AccentBrush" Color="#FF4FA3FF"/>
	<SolidColorBrush x:Key="AccentHoverBrush" Color="#FF73B6FF"/>
	<SolidColorBrush x:Key="AccentPressedBrush" Color="#FF2F7FE0"/>

	<SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FF1F2430"/>
	<SolidColorBrush x:Key="ControlHoverBrush" Color="#FF2A3242"/>
	<SolidColorBrush x:Key="ControlPressedBrush" Color="#FF242B3A"/>

	<!-- Window -->
	<Style TargetType="{x:Type Window}">
		<Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="FontFamily" Value="Segoe UI"/>
		<Setter Property="FontSize" Value="13"/>
	</Style>

	<!-- Button -->
	<Style TargetType="{x:Type Button}">
		<Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="12,7"/>
		<Setter Property="Cursor" Value="{DynamicResource AppCursor}"/>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
				<Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
			</Trigger>
			<Trigger Property="IsPressed" Value="True">
				<Setter Property="Background" Value="{DynamicResource ControlPressedBrush}"/>
				<Setter Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}"/>
			</Trigger>
			<Trigger Property="IsEnabled" Value="False">
				<Setter Property="Opacity" Value="0.55"/>
			</Trigger>
		</Style.Triggers>
	</Style>

	<!-- TextBox -->
	<Style TargetType="{x:Type TextBox}">
		<Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="8,6"/>
		<Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
		<Setter Property="SelectionBrush" Value="#664FA3FF"/>
		<Setter Property="SelectionTextBrush" Value="{DynamicResource TextBrush}"/>
	</Style>

	<!-- ListBox -->
	<Style TargetType="{x:Type ListBox}">
		<Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="6"/>
	</Style>

	<Style TargetType="{x:Type ListBoxItem}">
		<Setter Property="Padding" Value="8,6"/>
		<Setter Property="Margin" Value="0,2"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="#332A3242"/>
			</Trigger>
			<Trigger Property="IsSelected" Value="True">
				<Setter Property="Background" Value="#664FA3FF"/>
			</Trigger>
		</Style.Triggers>
	</Style>

	<!-- Стиль ТОЛЬКО для кнопок переключателя темы -->
	<Style x:Key="ThemeSwitchButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
		<Setter Property="Background" Value="#FF0E5AA7"/>
		<Setter Property="BorderBrush" Value="#FF73B6FF"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="BorderThickness" Value="1"/>

		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="#FF1670CC"/>
			</Trigger>
			<Trigger Property="IsPressed" Value="True">
				<Setter Property="Background" Value="#FF0B4B8D"/>
			</Trigger>
		</Style.Triggers>
	</Style>

</ResourceDictionary>