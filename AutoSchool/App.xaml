<Application x:Class="AutoSchool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:AutoSchool.Infrastructure"
             StartupUri="Views/LoginWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <!-- чтобы не падало на custom1.cur -->
            <Cursor x:Key="AppCursor">Arrow</Cursor>

            <infra:ByteArrayToImageSourceConverter x:Key="BytesToImage" />

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Win10.xaml" />
                <ResourceDictionary Source="Themes/LightTheme.xaml" />

                <!-- RU всегда базовый -->
                <ResourceDictionary Source="Localization/Strings.xaml" />
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>
</Application>